[user]
	name = Will Dixon
	email = dixonwille@hotmail.com
[push]
	default = simple
[core]
	autocrlf = input
[color]
	ui = true
[pull]
	rebase = true
[alias]
	s = status -s
	lg = log --oneline --decorate --all --graph
	bcm = "!f() { git branch --merged ${1-master} | grep -v " ${1-master}$" | xargs git branch -d; }; f"
[url "git@github.com:"]
	insteadof = https://github.com/
[include]
	path = .gitconfig_custom
